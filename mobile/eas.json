{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "22.15.0",
      "ios": { "simulator": false }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "node": "22.15.0",
      "ios": { "image": "latest" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "anpato@proton.me",
        "appleTeamId": "BX2YF52233"
      }
    }
  }
}
